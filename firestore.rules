rules_version = '2';

// Copia de referencia de las reglas de seguridad de Firestore para este proyecto.
// Este archivo NO se aplica solo: la app no usa el CLI de Firebase (no hay
// firebase.json ni despliegue automático), así que cualquier cambio aquí hay
// que pegarlo también a mano en la consola de Firebase
// (Firestore Database → Reglas → Publicar) para que tenga efecto real.
//
// Cada usuario solo puede leer y escribir su propia carpeta /usuarios/{uid},
// comprobando que la sesión activa (request.auth) pertenece a ese mismo uid.
service cloud.firestore {
  match /databases/{database}/documents {
    match /usuarios/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
